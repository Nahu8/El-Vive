# Copiá este archivo a .env y completá los valores. NUNCA subas .env al repositorio.
# El frontend Angular NO debe contener contraseñas ni datos de base de datos.

NODE_ENV=development

# Puerto HTTP del API (Hostinger Node suele asignar uno vía process.env.PORT)
PORT=4100

# JWT: en producción obligatorio, mínimo 32 caracteres aleatorios (openssl rand -base64 48)
JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres-seguros

# Orígenes del sitio Angular (producción: lista separada por comas, sin espacios extra)
# Ejemplo: https://elvive.org,https://www.elvive.org
CORS_ORIGIN=

# --- Base de datos ---
# Sin DB_HOST se usa SQLite local (data/elvive.db). Con MySQL (Hostinger) definí todo lo siguiente:

DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Opcional: límite de conexiones del pool (default 10, máx 25)
DB_POOL_LIMIT=10

# SSL hacia MySQL remoto (Hostinger a veces requiere true)
DB_SSL=false
# Si DB_SSL=true, por defecto se verifica el certificado; poné false solo si sabés el riesgo
DB_SSL_REJECT_UNAUTHORIZED=true

# Ruta al archivo SQLite (solo si NO usás MySQL)
# DB_PATH=./data/elvive.db

# --- Solo para script init-db en SQLite (opcional) ---
# INIT_SUPERADMIN_USER=
# INIT_SUPERADMIN_PASSWORD=

# Probar conexión MySQL: npm run check-mysql

# --- Angular (mismo dominio que Node en Hostinger) ---
# Opcional: ruta absoluta al contenido de ng build (carpeta browser con index.html).
# Si no se define, se usa ../frontend/dist/frontend/browser (monorepo) o ./public junto al backend.
# ANGULAR_DIST=
