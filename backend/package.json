{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API Node.js para Él Vive Iglesia (reemplazo del backend PHP)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "init-db": "node src/db/init.js",
    "check-mysql": "node scripts/check-mysql.mjs",
    "build:frontend": "npm --prefix ./frontend install && npm --prefix ./frontend run build",
    "copy:spa": "node scripts/copy-spa-to-public.mjs",
    "build": "npm run build:frontend && npm run copy:spa"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0"
  }
}
